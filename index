<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Configuratore · contratto auto senza riscatto · VAN con inflazione</title>
    <style>
        * {
            box-sizing: border-box;
            font-family: 'Segoe UI', Roboto, system-ui, sans-serif;
        }
        body {
            background: #f0f4f8;
            margin: 0;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .card {
            max-width: 1100px;
            width: 100%;
            background: white;
            border-radius: 32px;
            box-shadow: 0 20px 40px rgba(0,20,30,0.15);
            overflow: hidden;
            transition: all 0.2s;
        }
        .header {
            background: linear-gradient(135deg, #0b3954, #0e5b7c);
            color: white;
            padding: 28px 32px;
        }
        .logo {
            font-size: 1.4rem;
            font-weight: 300;
            letter-spacing: 1px;
            margin-bottom: 8px;
            opacity: 0.95;
            border-bottom: 1px solid rgba(255,255,255,0.2);
            padding-bottom: 8px;
            display: inline-block;
        }
        .logo strong {
            font-weight: 600;
            font-style: italic;
            background: rgba(255,255,255,0.15);
            padding: 2px 8px;
            border-radius: 40px;
        }
        .header h1 {
            margin: 0;
            font-weight: 500;
            font-size: 1.9rem;
            letter-spacing: -0.5px;
        }
        .header p {
            margin: 8px 0 0;
            opacity: 0.8;
            font-size: 1rem;
        }
        .content {
            padding: 32px;
        }
        /* Istruzioni */
        .instructions {
            background: #dff0fa;
            border-left: 6px solid #0b3954;
            border-radius: 20px;
            padding: 20px 24px;
            margin-bottom: 30px;
            font-size: 0.95rem;
            color: #1e3b4c;
        }
        .instructions h3 {
            margin: 0 0 12px 0;
            font-weight: 600;
            font-size: 1.3rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .instructions ul {
            margin: 0;
            padding-left: 20px;
        }
        .instructions li {
            margin: 8px 0;
        }
        .grid-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 28px 40px;
        }
        .input-group {
            margin-bottom: 20px;
        }
        .input-group label {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 600;
            color: #1e3b4c;
            margin-bottom: 8px;
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.3px;
        }
        .input-group label i {
            font-style: normal;
            font-size: 1.2rem;
        }
        .input-wrapper {
            display: flex;
            align-items: center;
            background: #f2f7fb;
            border-radius: 20px;
            padding: 0 18px;
            border: 1px solid #d9e6f0;
            transition: 0.2s;
        }
        .input-wrapper:focus-within {
            border-color: #0e5b7c;
            box-shadow: 0 0 0 3px rgba(14,91,124,0.15);
        }
        .input-wrapper input, .input-wrapper select {
            width: 100%;
            padding: 14px 0 14px 8px;
            border: none;
            background: transparent;
            font-size: 1rem;
            font-weight: 500;
            outline: none;
        }
        .input-wrapper select {
            cursor: pointer;
        }
        .input-wrapper span {
            color: #557a8c;
            font-weight: 500;
            margin-left: 4px;
        }
        .inline-hint {
            font-size: 0.8rem;
            color: #4d6a7a;
            margin-top: 6px;
            padding-left: 12px;
        }
        .separator {
            border-top: 2px dashed #cbdae6;
            margin: 30px 0 20px;
        }
        .param-section {
            background: #eaf1f8;
            border-radius: 24px;
            padding: 24px;
            margin: 30px 0 20px;
        }
        .param-section h3 {
            margin: 0 0 20px 0;
            color: #0b3954;
            font-weight: 600;
            font-size: 1.3rem;
        }
        .param-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 18px;
        }
        .results {
            background: #e7f0f9;
            border-radius: 28px;
            padding: 28px;
            margin-top: 30px;
        }
        .results h2 {
            margin: 0 0 20px 0;
            font-weight: 600;
            color: #0b3954;
            font-size: 1.6rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .results h2 span {
            background: #0b3954;
            color: white;
            font-size: 1rem;
            padding: 4px 14px;
            border-radius: 40px;
        }
        .section-header {
            font-weight: 600;
            color: #0b3954;
            background: #d0e2f0;
            padding: 8px 16px;
            border-radius: 30px;
            margin: 20px 0 10px 0;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .result-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px solid #c2d6e6;
            font-size: 1.05rem;
        }
        .result-row:last-child {
            border-bottom: none;
        }
        .result-label {
            font-weight: 500;
            color: #1b4c63;
        }
        .result-value {
            font-weight: 700;
            color: #0b2c3b;
            background: white;
            padding: 4px 20px;
            border-radius: 40px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.02);
        }
        .note {
            font-size: 0.85rem;
            color: #3f6279;
            margin-top: 25px;
            background: #d9e6f3;
            padding: 14px 22px;
            border-radius: 50px;
            text-align: center;
        }
        .button-email {
            background: #0b3954;
            color: white;
            border: none;
            padding: 16px 32px;
            font-size: 1.2rem;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 600;
            margin-top: 30px;
            width: 100%;
            transition: 0.2s;
        }
        .button-email:hover {
            background: #0e5b7c;
        }
        footer {
            text-align: center;
            font-size: 0.9rem;
            color: #6c8b9c;
            padding: 20px 32px 24px;
            background: #f0faff;
            border-top: 1px solid #d0e0ec;
        }
        .footer-site {
            font-size: 1.2rem;
            font-weight: 600;
            color: #0b3954;
            margin-top: 10px;
            letter-spacing: 0.5px;
        }
        @media (max-width: 700px) {
            .grid-2 { grid-template-columns: 1fr; gap: 0; }
            .param-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
<div class="card">
    <div class="header">
        <!-- Logo testuale moderno -->
        <div class="logo">
            <strong>e_GO'</strong> corrente in movimento
        </div>
        <h1>⚡ Centrale solare · contratto auto senza riscatto · VAN con inflazione</h1>
        <p>Costo materia prima casa, costo EV separato, beneficio %. Inflazione per VAN.</p>
    </div>
    <div class="content">
        <!-- Istruzioni per la compilazione -->
        <div class="instructions">
            <h3>📝 Come compilare il modulo</h3>
            <ul>
                <li><strong>1. Dati principali</strong> – Inserisci il costo annuo della tua bolletta elettrica, i km percorsi con l'auto termica e la potenza del fotovoltaico che intendi acquistare.</li>
                <li><strong>2. Veicolo elettrico</strong> – Indica modello, rata mensile, anticipo, durata del canone e km annui previsti per l'auto elettrica.</li>
                <li><strong>3. Parametri economici (modificabili)</strong> – Personalizza tutti i valori: costo materia prima casa, costo energia EV (indipendente), % di beneficio sui pannelli, costo carburante, consumo EV, produttività FV, costo impianto, valore residuo dopo 20 anni e tasso d'inflazione per il calcolo del VAN.</li>
                <li><strong>4. I risultati si aggiornano automaticamente</strong> – In fondo alla pagina puoi richiedere un'offerta via email con i dati inseriti.</li>
            </ul>
        </div>

        <!-- Dati principali -->
        <div class="grid-2">
            <div>
                <div class="input-group">
                    <label><i>🏠</i> Costo annuo bolletta (casa)</label>
                    <div class="input-wrapper">
                        <input type="number" id="costoBollettaAnnuale" value="1200" step="50" min="0">
                        <span>€/anno</span>
                    </div>
                    <div class="inline-hint">Importo totale della bolletta elettrica annuale</div>
                </div>
                <div class="input-group">
                    <label><i>⛽</i> Percorrenza termica</label>
                    <div class="input-wrapper">
                        <input type="number" id="kmIce" value="15000" step="500" min="0">
                        <span>km/anno</span>
                    </div>
                </div>
                <div class="input-group">
                    <label><i>🔆</i> Potenza fotovoltaico</label>
                    <div class="input-wrapper">
                        <input type="number" id="kwp" value="4.5" step="0.1" min="0">
                        <span>kWp</span>
                    </div>
                </div>
            </div>
            <div>
                <div class="input-group">
                    <label><i>🚗</i> Modello / marca EV</label>
                    <div class="input-wrapper">
                        <input type="text" id="marcaEv" value="Tesla Model 3" placeholder="es. Tesla, Volkswagen...">
                    </div>
                </div>
                <div class="input-group">
                    <label><i>📆</i> Rata mensile</label>
                    <div class="input-wrapper">
                        <input type="number" id="rata" value="350" step="10" min="0">
                        <span>€/mese</span>
                    </div>
                </div>
                <div class="input-group">
                    <label><i>💶</i> Anticipo</label>
                    <div class="input-wrapper">
                        <input type="number" id="anticipo" value="8000" step="500" min="0">
                        <span>€</span>
                    </div>
                </div>
                <div class="input-group">
                    <label><i>⏱️</i> Durata canone</label>
                    <div class="input-wrapper">
                        <select id="durataCanone">
                            <option value="36">36 mesi</option>
                            <option value="48" selected>48 mesi</option>
                            <option value="60">60 mesi</option>
                        </select>
                    </div>
                </div>
                <div class="input-group">
                    <label><i>🔁</i> Km annui EV</label>
                    <div class="input-wrapper">
                        <input type="number" id="kmEv" value="15000" step="500" min="0">
                        <span>km/anno</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sezione parametri personalizzabili -->
        <div class="param-section">
            <h3>🔧 Parametri economici e tecnici (modificabili)</h3>
            <div class="param-grid">
                <div class="input-group">
                    <label>⚡ Costo materia prima casa</label>
                    <div class="input-wrapper">
                        <input type="number" id="costoMateriaPrima" value="0.25" step="0.01" min="0">
                        <span>€/kWh</span>
                    </div>
                    <div class="inline-hint">Per la bolletta casa e beneficio pannelli</div>
                </div>
                <div class="input-group">
                    <label>🔋 Costo energia EV</label>
                    <div class="input-wrapper">
                        <input type="number" id="costoEnergiaEvKwh" value="0.25" step="0.01" min="0">
                        <span>€/kWh</span>
                    </div>
                    <div class="inline-hint">Indipendente dal costo casa (tariffa dedicata)</div>
                </div>
                <div class="input-group">
                    <label>📈 % beneficio cliente</label>
                    <div class="input-wrapper">
                        <input type="number" id="percentualeBeneficio" value="80" step="1" min="0" max="100">
                        <span>%</span>
                    </div>
                    <div class="inline-hint">Sul costo materia prima per kWh prodotto</div>
                </div>
                <div class="input-group">
                    <label>⛽ Costo carburante</label>
                    <div class="input-wrapper">
                        <input type="number" id="costoKmIce" value="0.12" step="0.01" min="0">
                        <span>€/km</span>
                    </div>
                </div>
                <div class="input-group">
                    <label>🔋 Consumo EV</label>
                    <div class="input-wrapper">
                        <input type="number" id="consumoEvPerKm" value="0.1667" step="0.0001" min="0">
                        <span>kWh/km</span>
                    </div>
                    <div class="inline-hint">0,1667 kWh/km = 6 km/kWh (15000 km → 2500 kWh)</div>
                </div>
                <div class="input-group">
                    <label>🌞 Prod. specifica FV</label>
                    <div class="input-wrapper">
                        <input type="number" id="prodSpecifica" value="1300" step="10" min="0">
                        <span>kWh/kWp</span>
                    </div>
                </div>
                <div class="input-group">
                    <label>🏗️ Costo impianto FV</label>
                    <div class="input-wrapper">
                        <input type="number" id="costoFvPerKwp" value="1500" step="50" min="0">
                        <span>€/kWp</span>
                    </div>
                </div>
                <div class="input-group">
                    <label>📅 Valore residuo FV dopo 20 anni</label>
                    <div class="input-wrapper">
                        <input type="number" id="valoreResiduo20" value="20" step="1" min="0" max="100">
                        <span>%</span>
                    </div>
                    <div class="inline-hint">Default 20%</div>
                </div>
                <!-- Inflazione annua % -->
                <div class="input-group">
                    <label>📈 Inflazione annua %</label>
                    <div class="input-wrapper">
                        <input type="number" id="tassoInflazione" value="2.0" step="0.1" min="0">
                        <span>%</span>
                    </div>
                    <div class="inline-hint">Per il calcolo del VAN</div>
                </div>
            </div>
        </div>

        <div class="separator"></div>

        <!-- Risultati -->
        <div class="results">
            <h2>📋 Proposta di investimento <span>simulazione</span></h2>
            <div id="risultatiDinamici">
                <!-- Sezione tecnica -->
                <div class="result-row">
                    <span class="result-label">🌞 Produzione solare attesa</span>
                    <span class="result-value" id="prodSolare">-- kWh</span>
                </div>
                <div class="result-row">
                    <span class="result-label">🏠 Consumo casa stimato</span>
                    <span class="result-value" id="consumoCasa">-- kWh</span>
                </div>
                <div class="result-row">
                    <span class="result-label">🔋 Consumo EV</span>
                    <span class="result-value" id="consumoEv">-- kWh</span>
                </div>
                <div class="result-row">
                    <span class="result-label">🔌 Consumo totale stimato</span>
                    <span class="result-value" id="consumoTotale">-- kWh</span>
                </div>

                <!-- INVESTIMENTO FOTOVOLTAICO (CAPITALE) -->
                <div class="section-header">🏦 INVESTIMENTO FOTOVOLTAICO</div>
                <div class="result-row">
                    <span class="result-label">🔆 Costo impianto FV</span>
                    <span class="result-value" id="costoImpiantoFV">-- €</span>
                </div>
                <div class="result-row">
                    <span class="result-label">📅 Valore residuo dopo 20 anni</span>
                    <span class="result-value" id="valoreResiduoInvestimento">-- €</span>
                </div>

                <!-- CONTRATTO AUTO SENZA RISCATTO -->
                <div class="section-header">🚗 CONTRATTO AUTO SENZA RISCATTO</div>
                <div class="result-row">
                    <span class="result-label">Anticipo auto</span>
                    <span class="result-value" id="anticipoDetail">-- €</span>
                </div>
                <div class="result-row">
                    <span class="result-label">Totale rate auto (intero canone)</span>
                    <span class="result-value" id="totaleRateAuto">-- €</span>
                </div>

                <!-- CONTO ECONOMICO ANNUALE -->
                <div class="section-header">📊 CONTO ECONOMICO ANNUALE</div>
                <div class="result-row">
                    <span class="result-label">📄 Bolletta totale attuale (casa)</span>
                    <span class="result-value" id="bollettaAttuale">-- €/anno</span>
                </div>
                <div class="result-row">
                    <span class="result-label">⛽ Costo carburante precedente</span>
                    <span class="result-value" id="costoIce">-- €/anno</span>
                </div>
                <div class="result-row">
                    <span class="result-label"><strong>Totale costi precedenti (A)</strong></span>
                    <span class="result-value" id="costiPrecedenti">-- €/anno</span>
                </div>
                <div class="result-row" style="border-top: 1px dashed #a0bedb;"></div>
                <div class="result-row">
                    <span class="result-label">🏠 Costo energia casa (nuovo)</span>
                    <span class="result-value" id="costoEnergiaCasa">-- €/anno</span>
                </div>
                <div class="result-row">
                    <span class="result-label">🚗 Costo energia EV (nuovo, con tariffa separata)</span>
                    <span class="result-value" id="costoEnergiaEv">-- €/anno</span>
                </div>
                <div class="result-row">
                    <span class="result-label">🔌 Totale nuova bolletta</span>
                    <span class="result-value" id="nuovaBolletta">-- €/anno</span>
                </div>
                <div class="result-row">
                    <span class="result-label">💰 Beneficio da pannelli (produzione × materia prima casa × %)</span>
                    <span class="result-value" id="beneficioPannelli">-- €/anno</span>
                </div>
                <div class="result-row">
                    <span class="result-label"><strong>Costi operativi netti (B = nuova bolletta - beneficio)</strong></span>
                    <span class="result-value" id="costiNetto">-- €/anno</span>
                </div>
                <div class="result-row" style="border-top: 2px solid #a0bedb; margin-top: 10px; padding-top: 16px;">
                    <span class="result-label" style="font-size: 1.2rem;">💥 RISPARMIO OPERATIVO (A - B)</span>
                    <span class="result-value" style="background: #0b3954; color: white; font-size: 1.3rem;" id="risparmioOperativo">-- €</span>
                </div>

                <!-- RIEPILOGO REDDITIVITÀ FV -->
                <div class="section-header">📈 RIENTRO INVESTIMENTO FV</div>
                <div class="result-row">
                    <span class="result-label">🏦 Investimento FV</span>
                    <span class="result-value" id="investimentoFV">-- €</span>
                </div>
                <div class="result-row">
                    <span class="result-label">📈 ROI annuo (risparmio / investimento)</span>
                    <span class="result-value" id="roiFV">-- %</span>
                </div>
                <div class="result-row">
                    <span class="result-label">⏳ Payback semplice</span>
                    <span class="result-value" id="paybackFV">-- anni</span>
                </div>
                <div class="result-row">
                    <span class="result-label">📅 Valore residuo dopo 20 anni</span>
                    <span class="result-value" id="valoreResiduo20Anni">-- €</span>
                </div>
                <div class="result-row">
                    <span class="result-label">🚗 Risparmio carburante (ICE→EV) - informativo</span>
                    <span class="result-value" id="risparmioCarburante">-- €/anno</span>
                </div>

                <!-- FLUSSO DI CASSA 20 ANNI (con VAN) -->
                <div class="section-header">📈 FLUSSO DI CASSA PREVISIONALE 20 ANNI</div>
                <div class="result-row">
                    <span class="result-label">💰 Risparmio annuo (costante)</span>
                    <span class="result-value" id="cashRisparmioAnnuo">-- €</span>
                </div>
                <div class="result-row">
                    <span class="result-label">📆 Risparmio totale in 20 anni (nominale)</span>
                    <span class="result-value" id="cashRisparmioTotale">-- €</span>
                </div>
                <div class="result-row">
                    <span class="result-label">🔆 Investimento iniziale FV</span>
                    <span class="result-value" id="cashInvestimento">-- €</span>
                </div>
                <div class="result-row">
                    <span class="result-label">📅 Valore residuo finale</span>
                    <span class="result-value" id="cashResiduo">-- €</span>
                </div>
                <div class="result-row" style="border-top: 2px solid #a0bedb; margin-top: 10px; padding-top: 16px;">
                    <span class="result-label" style="font-size: 1.2rem;">💼 FLUSSO NETTO NOMINALE</span>
                    <span class="result-value" style="background: #0b3954; color: white; font-size: 1.3rem;" id="cashNettoNominale">-- €</span>
                </div>
                <div class="result-row" style="border-top: 2px solid #a0bedb; margin-top: 10px; padding-top: 16px;">
                    <span class="result-label" style="font-size: 1.2rem;">📉 VAN (attualizzato al tasso inflazione)</span>
                    <span class="result-value" style="background: #0b3954; color: white; font-size: 1.3rem;" id="vanAttualizzato">-- €</span>
                </div>
                <div class="note" style="margin-top: 15px;">
                    ⚡ Il VAN è calcolato attualizzando i risparmi annuali e il valore residuo con il tasso di inflazione inserito.
                </div>
            </div>
            <div class="note" id="notaPayback">
                <strong>✅</strong> Il costo energia EV è indipendente dal costo materia prima casa. Tutti i campi sono modificabili.
            </div>

            <!-- PULSANTE EMAIL -->
            <button class="button-email" id="btnInviaEmail">📧 Richiedi offerta a info@ectenergy.co.uk</button>
        </div>
    </div>
    <!-- FOOTER con sito web -->
    <footer>
        <div>⚙️ Costo EV separato · contratto auto senza riscatto · VAN con inflazione</div>
        <div class="footer-site">🌐 www.ego.ectenergy.co.uk</div>
    </footer>
</div>

<script>
    (function() {
        // Recupero input principali
        const inputCostoBolletta = document.getElementById('costoBollettaAnnuale');
        const inputKmIce = document.getElementById('kmIce');
        const inputKwp = document.getElementById('kwp');
        const inputRata = document.getElementById('rata');
        const inputAnticipo = document.getElementById('anticipo');
        const inputDurata = document.getElementById('durataCanone');
        const inputKmEv = document.getElementById('kmEv');

        // Recupero parametri
        const inputCostoMateriaPrima = document.getElementById('costoMateriaPrima');
        const inputCostoEnergiaEvKwh = document.getElementById('costoEnergiaEvKwh');
        const inputPercentualeBeneficio = document.getElementById('percentualeBeneficio');
        const inputCostoKmIce = document.getElementById('costoKmIce');
        const inputConsumoEvPerKm = document.getElementById('consumoEvPerKm');
        const inputProdSpecifica = document.getElementById('prodSpecifica');
        const inputCostoFvPerKwp = document.getElementById('costoFvPerKwp');
        const inputValoreResiduo20 = document.getElementById('valoreResiduo20');
        const inputTassoInflazione = document.getElementById('tassoInflazione');

        // Output esistenti
        const outProdSolare = document.getElementById('prodSolare');
        const outConsumoCasa = document.getElementById('consumoCasa');
        const outConsumoEv = document.getElementById('consumoEv');
        const outConsumoTot = document.getElementById('consumoTotale');
        const outCostoImpiantoFV = document.getElementById('costoImpiantoFV');
        const outAnticipoDetail = document.getElementById('anticipoDetail');
        const outTotaleRateAuto = document.getElementById('totaleRateAuto');
        const outBollettaAttuale = document.getElementById('bollettaAttuale');
        const outCostoIce = document.getElementById('costoIce');
        const outCostiPrecedenti = document.getElementById('costiPrecedenti');
        const outCostoEnergiaCasa = document.getElementById('costoEnergiaCasa');
        const outCostoEnergiaEv = document.getElementById('costoEnergiaEv');
        const outNuovaBolletta = document.getElementById('nuovaBolletta');
        const outBeneficioPannelli = document.getElementById('beneficioPannelli');
        const outCostiNetto = document.getElementById('costiNetto');
        const outRisparmioOperativo = document.getElementById('risparmioOperativo');
        const outInvestimentoFV = document.getElementById('investimentoFV');
        const outRoiFV = document.getElementById('roiFV');
        const outPaybackFV = document.getElementById('paybackFV');
        const outValoreResiduo20Anni = document.getElementById('valoreResiduo20Anni');
        const outRisparmioCarburante = document.getElementById('risparmioCarburante');
        const notaPayback = document.getElementById('notaPayback');

        // Output valore residuo in conto capitale
        const outValoreResiduoInvestimento = document.getElementById('valoreResiduoInvestimento');

        // Output cash flow (nominale e VAN)
        const outCashRisparmioAnnuo = document.getElementById('cashRisparmioAnnuo');
        const outCashRisparmioTotale = document.getElementById('cashRisparmioTotale');
        const outCashInvestimento = document.getElementById('cashInvestimento');
        const outCashResiduo = document.getElementById('cashResiduo');
        const outCashNettoNominale = document.getElementById('cashNettoNominale');
        const outVanAttualizzato = document.getElementById('vanAttualizzato');

        function formatEuro(val) {
            return val.toFixed(0) + ' €';
        }
        function formatPercentuale(val) {
            return val.toFixed(1) + ' %';
        }

        function aggiornaRisultati() {
            // Lettura input
            let costoBolletta = parseFloat(inputCostoBolletta.value) || 0;
            let kmIce = parseFloat(inputKmIce.value) || 0;
            let kwp = parseFloat(inputKwp.value) || 0;
            let rataMensile = parseFloat(inputRata.value) || 0;
            let anticipo = parseFloat(inputAnticipo.value) || 0;
            let durataMesi = parseInt(inputDurata.value) || 48;
            let kmEv = parseFloat(inputKmEv.value) || 0;

            // Parametri
            let costoMateriaPrima = parseFloat(inputCostoMateriaPrima.value) || 0;
            let costoEnergiaEvKwh = parseFloat(inputCostoEnergiaEvKwh.value) || 0;
            let percentualeBeneficio = parseFloat(inputPercentualeBeneficio.value) || 0;
            let costoKmIce = parseFloat(inputCostoKmIce.value) || 0;
            let consumoEvPerKm = parseFloat(inputConsumoEvPerKm.value) || 0;
            let prodSpecifica = parseFloat(inputProdSpecifica.value) || 0;
            let costoFvPerKwp = parseFloat(inputCostoFvPerKwp.value) || 0;
            let residuo20 = parseFloat(inputValoreResiduo20.value) || 0;
            let tassoInflazione = parseFloat(inputTassoInflazione.value) || 0; // in percentuale

            // Calcoli energetici
            let produzioneSolare = kwp * prodSpecifica;
            let consumoEv = kmEv * consumoEvPerKm;
            let consumiCasa = (costoMateriaPrima > 0) ? (costoBolletta / costoMateriaPrima) : 0;
            let consumoTotale = consumiCasa + consumoEv;

            // Costi precedenti
            let costoCarburantePre = kmIce * costoKmIce;
            let costiPrecedenti = costoBolletta + costoCarburantePre;

            // Nuova bolletta con costo EV separato
            let costoEnergiaCasa = consumiCasa * costoMateriaPrima;
            let costoEnergiaEv = consumoEv * costoEnergiaEvKwh;
            let nuovaBolletta = costoEnergiaCasa + costoEnergiaEv;

            // Beneficio dai pannelli (usa costoMateriaPrima)
            let beneficio = produzioneSolare * costoMateriaPrima * (percentualeBeneficio / 100);

            // Costi netti e risparmio
            let costiNetto = nuovaBolletta - beneficio;
            let risparmio = costiPrecedenti - costiNetto;

            // Investimento FV
            let investimentoFV = kwp * costoFvPerKwp;

            // ROI e payback
            let roi = (investimentoFV > 0) ? (risparmio / investimentoFV * 100) : 0;
            let payback = (risparmio > 0) ? (investimentoFV / risparmio) : Infinity;

            // Totale rate auto
            let totaleRateAuto = rataMensile * durataMesi;

            // Risparmio carburante informativo
            let costoEnergiaEvSeRete = consumoEv * costoEnergiaEvKwh;
            let risparmioCarburante = costoCarburantePre - costoEnergiaEvSeRete;

            // Valore residuo dopo 20 anni
            let valoreResiduo20Anni = investimentoFV * (residuo20 / 100);

            // Cash flow nominale
            let risparmioAnnuale = risparmio;
            let risparmioTotale20 = risparmioAnnuale * 20;
            let flussoNettoNominale = risparmioTotale20 + valoreResiduo20Anni - investimentoFV;

            // VAN attualizzato con tasso inflazione
            let tasso = tassoInflazione / 100;
            let van = 0;
            if (tasso > 0) {
                // formula rendita
                van = risparmioAnnuale * (1 - Math.pow(1 + tasso, -20)) / tasso;
                van += valoreResiduo20Anni / Math.pow(1 + tasso, 20);
                van -= investimentoFV;
            } else {
                // tasso zero = lineare
                van = flussoNettoNominale;
            }

            // Aggiornamento campi
            outProdSolare.innerText = produzioneSolare.toFixed(0) + ' kWh';
            outConsumoCasa.innerText = consumiCasa.toFixed(0) + ' kWh';
            outConsumoEv.innerText = consumoEv.toFixed(0) + ' kWh';
            outConsumoTot.innerText = consumoTotale.toFixed(0) + ' kWh';

            outCostoImpiantoFV.innerText = formatEuro(investimentoFV);
            outAnticipoDetail.innerText = formatEuro(anticipo);
            outTotaleRateAuto.innerText = formatEuro(totaleRateAuto);

            outBollettaAttuale.innerText = formatEuro(costoBolletta);
            outCostoIce.innerText = formatEuro(costoCarburantePre);
            outCostiPrecedenti.innerText = formatEuro(costiPrecedenti);
            outCostoEnergiaCasa.innerText = formatEuro(costoEnergiaCasa);
            outCostoEnergiaEv.innerText = formatEuro(costoEnergiaEv);
            outNuovaBolletta.innerText = formatEuro(nuovaBolletta);
            outBeneficioPannelli.innerText = formatEuro(beneficio);
            outCostiNetto.innerText = formatEuro(costiNetto);
            outRisparmioOperativo.innerText = formatEuro(risparmio);

            outInvestimentoFV.innerText = formatEuro(investimentoFV);
            outRoiFV.innerText = formatPercentuale(roi);
            outPaybackFV.innerText = (payback === Infinity) ? '∞' : payback.toFixed(1) + ' anni';
            outValoreResiduo20Anni.innerText = formatEuro(valoreResiduo20Anni);
            outRisparmioCarburante.innerText = formatEuro(risparmioCarburante);

            outValoreResiduoInvestimento.innerText = formatEuro(valoreResiduo20Anni);

            outCashRisparmioAnnuo.innerText = formatEuro(risparmioAnnuale);
            outCashRisparmioTotale.innerText = formatEuro(risparmioTotale20);
            outCashInvestimento.innerText = formatEuro(investimentoFV);
            outCashResiduo.innerText = formatEuro(valoreResiduo20Anni);
            outCashNettoNominale.innerText = formatEuro(flussoNettoNominale);
            outVanAttualizzato.innerText = formatEuro(van);

            // Nota payback
            if (risparmio > 0 && isFinite(payback)) {
                notaPayback.innerHTML = `<strong>✅</strong> Risparmio operativo annuo: ${formatEuro(risparmio)} · ROI ${formatPercentuale(roi)} · Payback FV: ${payback.toFixed(1)} anni. Valore residuo a 20 anni: ${formatEuro(valoreResiduo20Anni)}.`;
            } else if (risparmio <= 0) {
                notaPayback.innerHTML = '<strong>⚠️</strong> Il risparmio operativo non è positivo. Verifica i dati inseriti.';
            } else {
                notaPayback.innerHTML = '<strong>✅</strong> Il risparmio operativo ripagherà l\'investimento FV.';
            }

            // Evidenzia risparmio negativo
            if (risparmio < 0) {
                outRisparmioOperativo.style.background = '#b02e2e';
                outRisparmioOperativo.style.color = 'white';
            } else {
                outRisparmioOperativo.style.background = '#0b3954';
                outRisparmioOperativo.style.color = 'white';
            }
        }

        // Event listener
        const inputs = [
            inputCostoBolletta, inputKmIce, inputKwp, inputRata, inputAnticipo, inputDurata, inputKmEv,
            inputCostoMateriaPrima, inputCostoEnergiaEvKwh, inputPercentualeBeneficio, inputCostoKmIce,
            inputConsumoEvPerKm, inputProdSpecifica, inputCostoFvPerKwp, inputValoreResiduo20,
            inputTassoInflazione
        ];
        inputs.forEach(inp => inp.addEventListener('input', aggiornaRisultati));
        inputDurata.addEventListener('change', aggiornaRisultati);
        window.addEventListener('load', aggiornaRisultati);

        // Pulsante email
        document.getElementById('btnInviaEmail').addEventListener('click', function() {
            // Raccogli tutti i dati correnti
            let dati = {
                "Costo annuo bolletta (casa)": inputCostoBolletta.value + " €/anno",
                "Percorrenza termica": inputKmIce.value + " km/anno",
                "Potenza FV": inputKwp.value + " kWp",
                "Modello EV": document.getElementById('marcaEv').value,
                "Rata mensile": inputRata.value + " €/mese",
                "Anticipo auto": inputAnticipo.value + " €",
                "Durata canone": inputDurata.value + " mesi",
                "Km annui EV": inputKmEv.value + " km/anno",
                "Costo materia prima casa": inputCostoMateriaPrima.value + " €/kWh",
                "Costo energia EV": inputCostoEnergiaEvKwh.value + " €/kWh",
                "% beneficio cliente": inputPercentualeBeneficio.value + " %",
                "Costo carburante": inputCostoKmIce.value + " €/km",
                "Consumo EV": inputConsumoEvPerKm.value + " kWh/km",
                "Prod. specifica FV": inputProdSpecifica.value + " kWh/kWp",
                "Costo impianto FV": inputCostoFvPerKwp.value + " €/kWp",
                "Valore residuo FV dopo 20 anni": inputValoreResiduo20.value + " %",
                "Tasso inflazione annuo": inputTassoInflazione.value + " %",
                // Aggiungiamo anche alcuni risultati chiave
                "Risparmio operativo annuo": outRisparmioOperativo.innerText,
                "Investimento FV": outInvestimentoFV.innerText,
                "VAN attualizzato 20 anni": outVanAttualizzato.innerText
            };

            let corpo = "Richiesta di offerta con i seguenti dati:\n\n";
            for (let [key, value] of Object.entries(dati)) {
                corpo += `${key}: ${value}\n`;
            }
            corpo += "\n-- \nInviato dal configuratore online.";

            let oggetto = "Richiesta offerta fotovoltaico + EV";
            let mailto = `mailto:info@ectenergy.co.uk?subject=${encodeURIComponent(oggetto)}&body=${encodeURIComponent(corpo)}`;
            window.location.href = mailto;
        });
    })();
</script>
</body>
</html>
